# ============================================================
# AI Startup Incubator Agent - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.

# ----- IBM watsonx.ai Credentials -----
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
IBM_URL=https://us-south.ml.cloud.ibm.com
IBM_MODEL=ibm/granite-13b-instruct-v2

# ----- Flask Configuration -----
FLASK_SECRET_KEY=replace_with_a_long_random_secret_key
FLASK_ENV=development
FLASK_DEBUG=True

# ----- Database -----
DATABASE_PATH=database/incubator.db
